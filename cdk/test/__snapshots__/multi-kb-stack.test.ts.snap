    "ObservabilityDlqAlarmC01666B1": {
      "Properties": {
        "AlarmDescription": "Dead-letter queue has messages - indicates processing failures",
        "AlarmName": "multi-kb-dlq-messages",
        "ComparisonOperator": "GreaterThanThreshold",
        "Dimensions": [
          {
            "Name": "QueueName",
            "Value": {
              "Fn::GetAtt": [
                "StorageDlq06CDC238",
                "QueueName",
              ],
            },
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "ApproximateNumberOfMessagesVisible",
        "Namespace": "AWS/SQS",
        "Period": 300,
        "Statistic": "Maximum",
        "Threshold": 0,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "ObservabilityDreamCycleLockAlarm77376D62": {
      "Properties": {
        "AlarmDescription": "Dream cycle lock held for over 60 minutes - possible deadlock",
        "AlarmName": "multi-kb-dream-cycle-lock",
        "ComparisonOperator": "GreaterThanThreshold",
        "EvaluationPeriods": 1,
        "MetricName": "DreamCycleLockHeldMinutes",
        "Namespace": "MultiKB",
        "Period": 3600,
        "Statistic": "Sum",
        "Threshold": 60,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
