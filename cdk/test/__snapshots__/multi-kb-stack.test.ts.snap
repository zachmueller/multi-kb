              "Fn::Join": [
                "",
                [
                  "#!/bin/bash
function exitTrap(){
exitCode=$?
/opt/aws/bin/cfn-signal --stack TestStack --resource ComputeAsgASG33A9C744 --region us-east-1 -e $exitCode || echo 'Failed to send Cloudformation Signal'
}
trap exitTrap EXIT
set -euxo pipefail
dnf install -y amazon-cloudwatch-agent
for i in 1 2 3; do
  aws s3 cp s3://test-bucket/multi-kb/cli-linux-arm64 /usr/local/bin/multi-kb && chmod +x /usr/local/bin/multi-kb && break
  echo "CLI binary download attempt $i failed, retrying..."
  sleep $((2 ** (i - 1)))
done
test -x /usr/local/bin/multi-kb
git config --system credential.helper '!aws codecommit credential-helper $@'
git config --system credential.UseHttpPath true
mkdir -p /opt/multi-kb
for i in 1 2 3; do
  git clone https://git-codecommit.us-east-1.amazonaws.com/v1/repos/multi-kb /opt/multi-kb/repo && break
  echo "CodeCommit clone attempt $i failed, retrying..."
  sleep $((2 ** (i - 1)))
done
if [ ! -d /opt/multi-kb/repo/.git ]; then
  mkdir -p /opt/multi-kb/repo
  cd /opt/multi-kb/repo
  git init
  git remote add origin https://git-codecommit.us-east-1.amazonaws.com/v1/repos/multi-kb
fi
cat > /opt/multi-kb/config.yaml << 'CONFIGEOF'
mode: server
author: "multi-kb-server"

sqs:
  queue_url: "",
                  {
                    "Ref": "StorageQueueF784EBBA",
                  },
                  ""
  batch_size: 10

codecommit:
  repo_name: "multi-kb"
  region: "us-east-1"

s3:
  bucket: "",
                  {
                    "Ref": "StorageBucket5CB7C8EA",
                  },
                  ""
  region: "us-east-1"

opensearch:
  endpoint: "",
                  {
                    "Fn::GetAtt": [
                      "SearchCollectionE9B440CC",
                      "CollectionEndpoint",
                    ],
                  },
                  ""
  region: "us-east-1"

bedrock_kb:
  knowledge_base_id: "",
                  {
                    "Fn::GetAtt": [
                      "KnowledgeBaseB4CDAA8B",
                      "KnowledgeBaseId",
                    ],
                  },
                  ""
  data_source_id: "",
                  {
                    "Fn::GetAtt": [
                      "KnowledgeBaseDataSource867D63C8",
                      "DataSourceId",
                    ],
                  },
                  ""

tick_interval: "5m"

dream_cycle:
  interval: "3h"
  model_id: "anthropic.claude-sonnet-4-20250514"

recall_log:
  schedule: "02:00"
CONFIGEOF
mkdir -p /opt/aws/amazon-cloudwatch-agent/etc
cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json << 'CWEOF'
{"logs":{"logs_collected":{"files":{"collect_list":[{"file_path":"/var/log/multi-kb/server.log","log_group_name":"",
                  {
                    "Ref": "ObservabilityEc2CliLogGroup5914591E",
                  },
                  "","log_stream_name":"{instance_id}"}]}}}}
CWEOF
/opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl -a fetch-config -m ec2 -s -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json
mkdir -p /var/log/multi-kb
cat > /etc/systemd/system/multi-kb.service << 'UNITEOF'
[Unit]
Description=Multi-KB Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/multi-kb server --config /opt/multi-kb/config.yaml
WorkingDirectory=/opt/multi-kb/repo
Restart=on-failure
RestartSec=5
StandardOutput=append:/var/log/multi-kb/server.log
StandardError=append:/var/log/multi-kb/server.log
Environment=AWS_REGION=us-east-1
Environment=HOME=/root

[Install]
WantedBy=multi-user.target
UNITEOF
systemctl daemon-reload
systemctl enable --now multi-kb",
